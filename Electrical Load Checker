import math

print ('Electrical Load Checker')

phase = input('How many phase(1 or 3)? ')
voltage = float(input('Total Voltage: '))
power_w = float(input('Load (Watts): '))
power_factor = float(input('Power Factor(decimal): '))

if phase == '1':
    current = power_w / (voltage * power_factor)
elif phase == '3':
    current = power_w / (voltage * power_factor * math.sqrt(3))
else:
    print('Invalid phase. Enter 1 or 3')
    exit()

#Breaker Size and Wiring Size 
breaker_size = [10, 15, 20, 25, 30, 50, 80, 100, 125]

recommended_breaker = None
for size in breaker_size:
    if current <= size:
        recommended_breaker = size
        break

if recommended_breaker is None:
    recommended_breaker = "Check for larger size"


print("\n RESULTS")
print('Load Current =', round(current, 2), 'A')
print('Recommended Breaker Size =', recommended_breaker)